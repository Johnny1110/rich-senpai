# rich-senpai runtime configuration
#
# Every entry below has a sane default in core/config.py — you only need
# to set the keys you want to override. Numeric values must parse as int;
# blank or non-numeric values fall back to the default.

# --- LLM Provider -----------------------------------------------------------
# LLM_PROVIDER: [anthropic, ollama]
LLM_PROVIDER=ollama
# Model_ID(anthropic): [claude-haiku-4-5-20251001, claude-sonnet-4-6, claude-opus-4-7]
# Model_ID(ollama)   : [qwen3, qwen3.6] -> qwen3 5G need RAM, qwen3.6 need 22G RAM
MODEL_ID=qwen3.6

# --- ANTHROPIC only (setup when using anthropic model) ---------------------
# ANTHROPIC_API_KEY=sk-ant-api03-*********

# --- Agent loop -----------------------------------------------------------
# Maximum tool-call iterations per cycle before the loop force-exits.
MAX_ITERATIONS=40

# max_tokens passed to the LLM on each completion call.
MAX_TOKENS_PER_CALL=15000

# Token cap on short_memory.md before the agent gets a "summarize me" warning.
SHORT_MEMORY_TOKEN_BUDGET=3000

# Auto-compact triggers when estimate_tokens(messages) exceeds this.
TOKEN_THRESHOLD=400000

# How many turns without a TodoWrite call before the nag reminder is appended
# (only fires when there are open todos).
TODO_NAG_AFTER_ROUNDS=3

# --- Subagent (`task` tool) ----------------------------------------------
SUBAGENT_MAX_ITERATIONS=40
SUBAGENT_MAX_TOKENS=400000

# --- Teammate (spawn_teammate) -------------------------------------------
# Seconds between idle-phase polls.
TEAM_POLL_INTERVAL=5
# Idle phase exits after this many seconds with no work.
TEAM_IDLE_TIMEOUT=60
# max_tokens for teammate completion calls.
TEAM_MAX_TOKENS=8000

# --- Tool defaults --------------------------------------------------------
# Default timeout (seconds) for the bash tool.
BASH_DEFAULT_TIMEOUT=180
# Default timeout (seconds) for the http_request tool.
HTTP_DEFAULT_TIMEOUT=30
# Default timeout (seconds) for background_run / BackgroundManager.run.
BG_DEFAULT_TIMEOUT=360

# --- Paths ----------------------------------------------------------------
# Path to the short-term memory scratchpad. Read by AgentCore on cycle start
# and overwritten by the update_short_memory tool.

