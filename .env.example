# PostgreSQL connection — used by docker-compose and config.py
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=agent_db
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_password

# Connection pool sizing for db_operations.execute_sql
DB_POOL_MIN=1
DB_POOL_MAX=5

# Set to "true" to refuse any non-SELECT statements from execute_sql
DB_READ_ONLY=false
